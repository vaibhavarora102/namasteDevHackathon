# --- LLM (chat) provider: "anthropic" or "openai" ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Set only the key you need for the chosen LLM_PROVIDER
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# --- Embeddings provider (for the shared knowledge vector store) ---
# "huggingface" = local, free, no extra API key needed (default)
# "openai"      = uses OPENAI_API_KEY, requires an OpenAI key even if the
#                 chat LLM is Anthropic
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Storage ---
DATA_DIR=data

# --- Telemetry (SigNoz Observability) ---
ENABLE_TELEMETRY=true
OTEL_SERVICE_NAME=knowledge-share-agents
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
